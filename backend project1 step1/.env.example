# ============================================================================
# ENVIRONMENT VARIABLES — copy this file to ".env" and fill in real values.
#   cp .env.example .env
#
# Never commit the real ".env" file to git — it has secrets in it.
# (the .gitignore in this project already excludes it)
# ============================================================================

# ---- SUPABASE ----
# Find these in: Supabase Dashboard -> your project -> Project Settings (gear
# icon) -> API. There are 3 values on that page you need:

# "Project URL" — looks like https://xxxxx.supabase.co
SUPABASE_URL=

# "anon public" key — safe to expose to a browser, respects RLS policies.
# Note: newer Supabase projects label this "publishable" key instead of
# "anon" — either works the same way for our purposes.
SUPABASE_ANON_KEY=

# "service_role" key — NEVER expose this to a browser/frontend. It bypasses
# all RLS policies. Only our Express backend uses it, for the seed script
# and for admin-style operations like checking stock during checkout.
# Click "reveal" next to it in the dashboard to see it.
SUPABASE_SERVICE_ROLE_KEY=

# ---- RAZORPAY (TEST MODE) ----
# Find these in: Razorpay Dashboard -> make sure the "Test Mode" toggle
# (top right) is ON -> Settings -> API Keys -> Generate Test Key.

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- SERVER CONFIG ----

# Port the Express server runs on locally
PORT=4000

# The exact origin your frontend is served from. If you open the HTML file
# directly by double-clicking it, this is usually not applicable — but if
# you serve it via a local dev server (recommended), set it to match, e.g.
# http://localhost:5500 or http://127.0.0.1:5500
FRONTEND_ORIGIN=http://localhost:5500
